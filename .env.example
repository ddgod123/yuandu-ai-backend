APP_NAME=emoji
APP_ENV=dev
APP_PORT=5050

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=emojiDB
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_SEARCH_PATH="\"user\",archive,taxonomy,action,audit,public"

JWT_SECRET=change-me
JWT_ISSUER=emoji
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=720h

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emoji
MINIO_USE_SSL=false

ASYNQ_REDIS_ADDR=127.0.0.1:6379
ASYNQ_REDIS_PASSWORD=
ASYNQ_REDIS_DB=0
# Optional worker tuning:
# ASYNQ_CONCURRENCY=10
# ASYNQ_QUEUE_WEIGHTS=video_gif=4,video_png=4,media=2,default=4
# VIDEO_WORKER_ROLE=all  # all|gif|png|media
# Optional: enable admin one-click worker start (e.g. systemctl start emoji-worker)
WORKER_START_COMMAND=
# Optional: per-lane start/stop commands for admin monitor panel
WORKER_START_COMMAND_GIF=
WORKER_START_COMMAND_PNG=
WORKER_START_COMMAND_MEDIA=
WORKER_STOP_COMMAND=
WORKER_STOP_COMMAND_GIF=
WORKER_STOP_COMMAND_PNG=
WORKER_STOP_COMMAND_MEDIA=
WORKER_START_TIMEOUT_SECONDS=20
GIFSICLE_BIN=
# GIF render bundle/mezzanine（P1 提速灰度开关）
GIF_BUNDLE_ENABLED=true
GIF_MEZZANINE_ENABLED=true
GIF_BUNDLE_MERGE_GAP_MS=800
GIF_BUNDLE_MAX_SPAN_SEC=12
GIF_MEZZANINE_MIN_WINDOWS=2
GIF_MEZZANINE_CRF=18
GIF_MEZZANINE_PRESET=veryfast
# 默认 false：只使用 output_id/candidate_id 的严格反馈链路（推荐）
# 如需临时兼容 legacy feedback_v1，可设为 true
ENABLE_LEGACY_FEEDBACK_FALLBACK=false

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 开发阶段可留空（将走后端 SDK 直读对象 + /api/storage/proxy 兜底，不依赖已备案域名）。
QINIU_DOMAIN=
QINIU_ZONE=
QINIU_USE_HTTPS=true
QINIU_USE_CDN=false
QINIU_PRIVATE=false
QINIU_SIGN_TTL=3600
# 开发/测试兜底：源视频预探测失败时允许继续创建任务（生产建议 false）
VIDEO_SOURCE_PROBE_ALLOW_DEGRADED=true

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM={"code":"##code##"}
ALIYUN_SMS_VALID_TIME=300
ALIYUN_SMS_INTERVAL=60
ALIYUN_SMS_RETURN_CODE=false
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_DAILY_MAX_PHONE=20
ALIYUN_SMS_DAILY_MAX_IP=200
ALIYUN_SMS_DAILY_MAX_DEVICE=60
ALIYUN_SMS_DAILY_MAX_UNIQUE_PHONE_PER_IP=30
ALIYUN_SMS_DAILY_MAX_UNIQUE_PHONE_PER_DEVICE=20
LOGIN_DAILY_MAX_PHONE=50
LOGIN_DAILY_MAX_IP=300
LOGIN_DAILY_MAX_DEVICE=120
DEV_AUTH_ENABLED=false
DEV_AUTH_PHONE=13900000000,18800000000
DEV_AUTH_CODE=999999,123456
CAPTCHA_TTL_SECONDS=300
CAPTCHA_LENGTH=4
REGISTER_DAILY_MAX_DEVICE=3
REGISTER_DAILY_MAX_IP=20
AUTH_FAIL_WINDOW_SECONDS=600
AUTH_FAIL_LOCK_LEVEL1=5
AUTH_FAIL_LOCK_LEVEL2=12
AUTH_FAIL_LOCK_TTL1=600
AUTH_FAIL_LOCK_TTL2=3600

# Anti-abuse / anti-crawler limits
DOWNLOAD_EMOJI_PER_MINUTE_USER=120
DOWNLOAD_EMOJI_PER_MINUTE_IP=300
DOWNLOAD_EMOJI_PER_HOUR_USER=1200
DOWNLOAD_EMOJI_PER_HOUR_IP=3000
DOWNLOAD_COLLECTION_PER_HOUR_USER=20
DOWNLOAD_COLLECTION_PER_HOUR_IP=60
DOWNLOAD_COLLECTION_PER_DAY_USER=120
DOWNLOAD_COLLECTION_PER_DAY_IP=400
REDEEM_VALIDATE_PER_10MIN_USER=30
REDEEM_VALIDATE_PER_10MIN_IP=80
REDEEM_SUBMIT_PER_10MIN_USER=10
REDEEM_SUBMIT_PER_10MIN_IP=30
DOWNLOAD_TICKET_TTL=120
DOWNLOAD_TICKET_SIGN_TTL=180
DOWNLOAD_TICKET_BIND_IP=true
DOWNLOAD_TICKET_BIND_UA=true
RISK_AUTO_BLOCK_ENABLED=true
RISK_AUTO_BLOCK_THRESHOLD=10
RISK_AUTO_BLOCK_WINDOW_SECONDS=600
RISK_AUTO_BLOCK_DURATION_SECONDS=86400

TELEGRAM_BOT_TOKEN=
TELEGRAM_DOWNLOAD_DIR=/Users/mac/go/src/emoji/telegram_to_wechat
TELEGRAM_PROXY=socks5://127.0.0.1:10797

AUTH_ACCESS_COOKIE_NAME=emoji_access_token
AUTH_REFRESH_COOKIE_NAME=emoji_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

CORS_ALLOW_ORIGINS=http://localhost:5818,http://127.0.0.1:5818,http://localhost:5918,http://127.0.0.1:5918

# LLM provider routing (for AI planner/judge / cloud fallback)
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_MODEL=qwen3-vl-flash
LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode

# Stage1 AI Planner (Alibaba Qwen recommended)
AI_PLANNER_ENABLED=true
AI_PLANNER_PROVIDER=qwen
AI_PLANNER_API_KEY=
AI_PLANNER_MODEL=qwen3-vl-flash
AI_PLANNER_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode
AI_PLANNER_PROMPT_VERSION=gif_planner_v1
AI_PLANNER_TIMEOUT_SECONDS=20
AI_PLANNER_MAX_TOKENS=1200

# Stage0 AI Director (task-level prompt pack)
AI_DIRECTOR_ENABLED=true
AI_DIRECTOR_PROVIDER=qwen
AI_DIRECTOR_API_KEY=
AI_DIRECTOR_MODEL=qwen3-vl-flash
AI_DIRECTOR_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode
AI_DIRECTOR_PROMPT_VERSION=gif_director_v1
AI_DIRECTOR_TIMEOUT_SECONDS=16
AI_DIRECTOR_MAX_TOKENS=1000

# Stage3 AI Judge (DeepSeek recommended)
AI_JUDGE_ENABLED=true
AI_JUDGE_PROVIDER=deepseek
AI_JUDGE_API_KEY=
AI_JUDGE_MODEL=deepseek-chat
AI_JUDGE_ENDPOINT=https://api.deepseek.com
AI_JUDGE_PROMPT_VERSION=gif_judge_v1
AI_JUDGE_TIMEOUT_SECONDS=45
AI_JUDGE_MAX_TOKENS=1400

# Cloud highlight fallback (optional)
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_ENABLED=false
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_URL=
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_TOKEN=
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_MIN_SCORE=0.34
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_TIMEOUT_SEC=8
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_TOP_N=0
VIDEO_HIGHLIGHT_CLOUD_FALLBACK_SCENE_THRESHOLD=0.08

# Cost accounting
# USD->CNY FX rate used when merging AI token cost into ops.video_job_costs.estimated_cost
VIDEO_JOB_USD_TO_CNY_RATE=7.20
# Optional pricing override JSON (array), e.g.
# [{"provider":"qwen","model":"qwen3-vl-flash","input_per_1m":0.022,"output_per_1m":0.215,"currency":"USD","version":"v1","pricing_source_url":"https://..."}]
VIDEO_JOB_AI_PRICING_OVERRIDES_JSON=
